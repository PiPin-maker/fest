<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Льняная Палитра</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{
    background:#35567C;
    color:#F5F1ED;
    font-family:'Montserrat',sans-serif;
    overflow-x:hidden;
}

/* ========================= */
/* ОБЩИЕ */
/* ========================= */

section{
    padding:90px 8%;
}

h1,h2,h3{
    font-family:'Cormorant Garamond',serif;
    letter-spacing:2px;
}

.section-title{
    text-align:center;
    font-size:72px;
    margin-bottom:70px;
}

/* ========================= */
/* HERO */
/* ========================= */

.hero{
    min-height:100vh;
    position:relative;
    overflow:hidden;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    text-align:center;
}

.hero::before{
    content:'';
    position:absolute;
    width:1200px;
    height:1200px;
    border:2px solid rgba(255,255,255,0.06);
    transform:rotate(45deg);
    top:-500px;
    left:-300px;
}

.hero::after{
    content:'';
    position:absolute;
    width:900px;
    height:900px;
    border:2px solid rgba(255,255,255,0.05);
    transform:rotate(45deg);
    bottom:-400px;
    right:-250px;
}

.top-text{
    font-size:18px;
    letter-spacing:6px;
    margin-bottom:20px;
    z-index:2;
}

.main-title{
    font-size:92px;
    margin-bottom:10px;
    z-index:2;
}

.line{
    width:320px;
    height:2px;
    background:#F5F1ED;
    margin:20px auto 50px;
}

.date{
    font-size:28px;
    letter-spacing:5px;
    margin-bottom:60px;
    z-index:2;
}

/* ========================= */
/* MENU — ИСПРАВЛЕННАЯ СЕТКА */
/* ========================= */

.menu-grid{
    display:grid;
    grid-template-columns:repeat(3, 1fr);
    gap:35px;
    max-width:1150px;
    width:100%;
    z-index:2;
    margin:0 auto;
}

.menu-card{
    background:rgba(255,255,255,1.0);
    backdrop-filter:blur(10px);
    border:1px solid rgba(255,255,255,0.12);
    border-radius:30px;
    overflow:hidden;
    transition:0.45s;
    cursor:pointer;
    position:relative;
    aspect-ratio: 1 / 1; /* Делает карточки квадратными и одинаковыми */
    display:flex;
    align-items:center;
    justify-content:center;
    padding:20px;
}

.menu-card:hover{
    transform:translateY(-12px) scale(1.03);
    border-color:#F06B6B;
    box-shadow:0 0 35px rgba(240,107,107,0.35);
}

.menu-card img{
    width:100%;
    height:100%;
    object-fit:contain; /* Картинка помещается целиком */
    display:block;
    transition:0.4s;
}

.menu-card:hover img{
    transform:scale(1.03);
}

/* ========================= */
/* BUTTONS */
/* ========================= */

.buttons{
    margin-top:60px;
    display:flex;
    gap:25px;
    flex-wrap:wrap;
    justify-content:center;
    z-index:2;
}

.btn{
    padding:18px 42px;
    border:none;
    border-radius:50px;
    font-size:16px;
    cursor:pointer;
    transition:0.4s;
    font-weight:600;
}

.btn-main{
    background:#F5F1ED;
    color:#35567C;
}

.btn-main:hover{
    transform:scale(1.05);
}

.btn-accent{
    background:#F06B6B;
    color:white;
}

.btn-accent:hover{
    transform:scale(1.05);
}

.btn-disabled{
    background:rgba(255,255,255,0.1);
    color:rgba(255,255,255,0.5);
    cursor:not-allowed;
}

/* ========================= */
/* ПАСПОРТ */
/* ========================= */

.passport{
    background:#F5F1ED;
    color:#35567C;
    border-radius:40px;
    padding:60px;
    position:relative;
    overflow:hidden;
}

.passport h2{
    font-size:54px;
    margin-bottom:30px;
}

.passport-btn{
    background:#35567C;
    color:white;
    border:none;
    padding:18px 40px;
    border-radius:40px;
    font-size:16px;
    cursor:pointer;
    transition:0.4s;
}

.passport-btn:hover{
    transform:scale(1.05);
}

.passport-box{
    background:white;
    padding:40px;
    border-radius:25px;
    box-shadow:0 10px 30px rgba(0,0,0,0.08);
    margin-top:30px;
}

.passport-box p{
    margin:15px 0;
    font-size:18px;
    line-height:1.8;
}

/* ========================= */
/* MERCH */
/* ========================= */

.merch{
    padding-top:120px;
}

.volunteer-note{
    text-align:center;
    color:#F06B6B;
    font-size:22px;
    margin-bottom:18px;
    font-weight:600;
}

.merch-description{
    text-align:center;
    opacity:0.85;
    margin-bottom:40px;
    font-size:18px;
}

.merch-slider{
    overflow:hidden;
    width:100%;
    position:relative;
    margin-top:60px;
}

.merch-track{
    display:flex;
    gap:30px;
    width:max-content;
    animation:merchScroll 55s linear infinite;
}

@keyframes merchScroll{
    from{
        transform:translateX(0);
    }
    to{
        transform:translateX(-50%);
    }
}

.merch-card{
    width:320px;
    min-width:320px;
    background:rgba(255,255,255,0.05);
    border-radius:28px;
    overflow:hidden;
    border:1px solid rgba(255,255,255,0.08);
    transition:0.4s;
}

.merch-card:hover{
    transform:translateY(-12px);
}

.merch-card img{
    width:100%;
    height:340px;
    object-fit:cover;
    display:block;
}

.merch-content{
    padding:25px;
}

.merch-content h3{
    font-size:34px;
    margin-bottom:14px;
    font-family:'Cormorant Garamond',serif;
}

.price{
    color:#F06B6B;
    font-size:22px;
    margin-bottom:8px;
    font-weight:600;
}

.stamps{
    opacity:0.85;
    font-size:17px;
}

.volunteer-card{
    border:1px solid #F06B6B;
}

.badge-text{
    color:#F06B6B;
    line-height:1.7;
    font-size:17px;
}

/* ========================= */
/* HISTORY */
/* ========================= */

.history{
    background:#35567C;
    color:#ffffff;
}

.history-box{
    max-width:1100px;
    margin:auto;
    background:#837bdf33;
    border-radius:30px;
    padding:60px;
    line-height:2;
    font-size:18px;
    box-shadow:0 10px 40px rgba(0,0,0,0.08);
}

.history-box p{
    margin-bottom:25px;
}

/* ========================= */
/* FOOTER */
/* ========================= */

footer{
    padding:80px 8%;
    text-align:center;
    opacity:0.7;
}

/* ========================= */
/* АДАПТИВ */
/* ========================= */

@media(max-width:900px){
    .main-title{
        font-size:58px;
    }
    .section-title{
        font-size:50px;
    }
    .menu-grid{
        grid-template-columns:repeat(2, 1fr); /* На планшетах 2 колонки */
    }
    .menu-card{
        aspect-ratio: 1 / 1;
    }
    .passport{
        padding:30px;
    }
    .history-box{
        padding:35px;
    }
    .buttons{
        flex-direction:column;
        align-items:center;
    }
}

@media(max-width:550px){
    .menu-grid{
        grid-template-columns:1fr; /* На телефонах 1 колонка */
    }
    .main-title{
        font-size:42px;
    }
    .section-title{
        font-size:36px;
    }
    .date{
        font-size:20px;
    }
}

</style>
</head>
